{
  "name": "standup-cli",
  "version": "1.0.0",
  "description": "CLI tool that summarises your recent git commits into a daily standup using AI",
  "main": "dist/index.js",
  "bin": {
    "standup": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "keywords": [
    "git",
    "cli",
    "standup",
    "ai"
  ],
  "author": "Kahlan Hagerman",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
